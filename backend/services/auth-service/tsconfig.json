{
  "compilerOptions": {
    "outDir": "./dist",

    "module": "commonjs",
    "target": "ES2021",
    "moduleResolution": "node",

    "sourceMap": true,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "baseUrl": ".",
  },

  "include": [
    "src/**/*",
    "../../shared/**/*",
  ],

  "exclude": ["node_modules"],
}