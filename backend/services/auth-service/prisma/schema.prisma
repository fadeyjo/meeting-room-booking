datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

model persons {
  person_id Int @id @default(autoincrement())
  created_at DateTime
  email String @unique
  phone_number String @unique
  birth DateTime
  last_name String
  first_name String
  patronymic String?
  position_id Int
  hashed_password String
  role_id Int
  fired_at DateTime?

  refresh_tokens refresh_tokens[]

  role roles @relation(fields: [role_id], references: [role_id])
  position positions @relation(fields: [position_id], references: [position_id])
}

model refresh_tokens {
  token_id Int @id @default(autoincrement())
  hashed_token String @unique
  person_id Int
  expires DateTime
  is_revoked Boolean

  person persons @relation(fields: [person_id], references: [person_id])
}

model roles {
  role_id Int @id @default(autoincrement())
  role_name String @unique

  persons persons[]
}

model positions  {
  position_id Int @id @default(autoincrement())
  position String @unique

  persons persons[]
}